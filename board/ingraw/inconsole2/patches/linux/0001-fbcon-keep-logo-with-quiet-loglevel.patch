From 3e7f72e6639c418d0919e2f914a06e9fca9330f8 Mon Sep 17 00:00:00 2001
From: InGraw <ingraw | mateusz lademann>
Date: Sat, 7 Mar 2026 16:30:00 +0000
Subject: [PATCH] fbcon: keep boot logo visible when console loglevel is quiet

In this project we intentionally run with low console loglevel to hide
boot warnings on the LCD, but we still want to keep the custom kernel
logo visible on tty0.

Do not disable logo drawing based on console_loglevel.
---
 drivers/video/fbdev/core/fbcon.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/drivers/video/fbdev/core/fbcon.c b/drivers/video/fbdev/core/fbcon.c
index 8a6df22ec11b..8a8f8dbe7f5e 100644
--- a/drivers/video/fbdev/core/fbcon.c
+++ b/drivers/video/fbdev/core/fbcon.c
@@ -1032,9 +1032,6 @@ static void fbcon_init(struct vc_data *vc, bool init)
 
 	info = fbcon_info_from_console(vc->vc_num);
 
-	if (logo_shown < 0 && console_loglevel <= CONSOLE_LOGLEVEL_QUIET)
-		logo_shown = FBCON_LOGO_DONTSHOW;
-
 	if (vc != svc || logo_shown == FBCON_LOGO_DONTSHOW ||
 	    (info->fix.type == FB_TYPE_TEXT))
 		logo = 0;
-- 
2.43.0

